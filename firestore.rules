rules_version = '2';

// Phase 1 rules. Users own their own document; any signed-in user can
// create an organization; projects are scoped to the organization and
// visible only to their member list. Rules for expenses, staff,
// attendance, files and material requests land alongside those features.
service cloud.firestore {
  match /databases/{database}/documents {

    function isOrgMember(orgId) {
      return request.auth != null
        && orgId is string
        && exists(/databases/$(database)/documents/organizations/$(orgId))
        && request.auth.uid in get(/databases/$(database)/documents/organizations/$(orgId)).data.memberIds;
    }

    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /organizations/{orgId} {
      // Any signed-in user can create an org, and they must name themselves
      // as the owner + sole initial member. Prevents one user seeding an
      // org under someone else's uid.
      allow create: if request.auth != null
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.memberIds is list
        && request.resource.data.memberIds.size() == 1
        && request.resource.data.memberIds[0] == request.auth.uid;

      // Reads and updates are restricted to org members. Membership is
      // mutated server-side (via Cloud Functions) in the invite flow, so
      // clients can't grant themselves access.
      allow read, update: if request.auth != null
        && request.auth.uid in resource.data.memberIds;

      // Deletion is locked down entirely for now.
      allow delete: if false;
    }

    match /projects/{projectId} {
      allow create: if request.auth != null
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.orgId is string
        && request.resource.data.memberIds is list
        && request.resource.data.memberIds.size() >= 1
        && request.auth.uid in request.resource.data.memberIds;

      // Read / update: any member of the project's org. Using
      // isOrgMember() (instead of project.memberIds) lets list queries
      // work — Firestore evaluates list rules per-doc, so a single
      // legacy project missing the user's uid in its memberIds would
      // otherwise reject the whole list. Org membership is the right
      // boundary here since `where('orgId', '==', myOrg)` already
      // filters the query client-side.
      allow read, update: if isOrgMember(resource.data.orgId);

      allow delete: if request.auth != null
        && request.auth.uid == resource.data.ownerId;
    }

    // ── Transactions (project-scoped) ──
    match /transactions/{txnId} {
      allow read, write: if request.auth != null;
    }

    // ── Parties (org-scoped) ──
    match /parties/{partyId} {
      allow read, write: if request.auth != null;
    }

    // ── Attendance (project-scoped) ──
    // Per-day attendance records. Scoped to org members so historical
    // data can't leak across orgs. Create / update / delete are gated
    // on the writer being a member of the record's org.
    match /attendance/{recordId} {
      allow read, update, delete: if isOrgMember(resource.data.orgId);
      allow create: if isOrgMember(request.resource.data.orgId)
        && request.resource.data.projectId is string
        && request.resource.data.labourId is string
        && request.resource.data.date is string;
    }

    // ── Project Labour Roster (project-scoped master list) ──
    // Source-of-truth labour list per project. Used to render the
    // attendance roster across every date (incl. dates with no marks
    // yet). Any org member may upsert / read; write is open across
    // members so silent backfill from existing attendance docs works
    // regardless of who originally marked the labour.
    match /projectLabour/{labourId} {
      allow read, update, delete: if isOrgMember(resource.data.orgId);
      allow create: if isOrgMember(request.resource.data.orgId)
        && request.resource.data.projectId is string
        && request.resource.data.labourId is string;
    }

    // ── Materials (project-scoped) ──
    match /materials/{materialId} {
      allow read, write: if request.auth != null;
    }

    // ── Material Library (org-scoped catalog) ──
    match /materialLibrary/{itemId} {
      allow read, write: if request.auth != null;
    }

    // ── Task Category Library (org-scoped catalog) ──
    match /taskCategoryLibrary/{itemId} {
      allow read: if isOrgMember(resource.data.orgId);
      allow create: if isOrgMember(request.resource.data.orgId);
      allow update, delete: if isOrgMember(resource.data.orgId);
    }

    // ── Material Requests (project-scoped) ──
    match /materialRequests/{requestId} {
      allow read, write: if request.auth != null;
    }

    // ── Tasks (project-scoped) ──
    match /tasks/{taskId} {
      allow read, write: if request.auth != null;

      // Progress update feed — append-only posts with %, note, photos.
      match /updates/{updateId} {
        allow read, create: if request.auth != null;
        allow update, delete: if false;
      }

      // Legacy comment log — kept for back-compat until migrated.
      match /comments/{commentId} {
        allow read, create: if request.auth != null;
        allow update, delete: if false;
      }
    }

    // ── Daily Progress Reports (project-scoped, one per date) ──
    match /dpr/{dprId} {
      allow read, write: if request.auth != null;
    }

    // ── Minutes of Meeting (project-scoped) ──
    match /moms/{momId} {
      allow read, write: if request.auth != null;
    }

    // ── Laminates (project-scoped) ──
    match /laminates/{laminateId} {
      allow read, write: if request.auth != null;
    }

    // ── Whiteboards (project-scoped vector sketch documents) ──
    match /whiteboards/{boardId} {
      allow read: if isOrgMember(resource.data.orgId);
      allow create: if isOrgMember(request.resource.data.orgId)
        && request.resource.data.projectId is string
        && request.resource.data.authorId == request.auth.uid;
      // Any org member can edit boards (collaborative). orgId / projectId /
      // authorId are immutable.
      allow update: if isOrgMember(resource.data.orgId)
        && request.resource.data.orgId == resource.data.orgId
        && request.resource.data.projectId == resource.data.projectId
        && request.resource.data.authorId == resource.data.authorId;
      // Only the original author may delete their board.
      allow delete: if isOrgMember(resource.data.orgId)
        && resource.data.authorId == request.auth.uid;
    }

    // ── CRM: Leads & Appointments (org-scoped) ──
    match /leads/{leadId} {
      allow read, update, delete: if isOrgMember(resource.data.orgId);
      allow create: if isOrgMember(request.resource.data.orgId);
    }

    match /appointments/{appointmentId} {
      allow read, update, delete: if isOrgMember(resource.data.orgId);
      allow create: if isOrgMember(request.resource.data.orgId);
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
