# SiteExpens — environment variables
#
# Copy this file to `.env` (gitignored) and fill in real values.
# Values prefixed with EXPO_PUBLIC_ are bundled into the client. NEVER put
# server-only secrets (R2 keys, admin SDK keys) under EXPO_PUBLIC_.

# ── Firebase (client) ────────────────────────────────────────────────
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=

# ── Cloudflare R2 (server-only, used inside functions/) ──────────────
# These are read by Cloud Functions via `firebase functions:secrets:set`
# in production. Local development uses these env vars.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE_URL=
