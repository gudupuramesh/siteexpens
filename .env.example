# MSG91 — React Native SDK (`@msg91comm/sendotp-react-native`, see `src/features/auth/phoneAuth.ts`)
#
# Official requirement: enable **Mobile Integration** when configuring the widget, or the SDK returns:
#   "Mobile requests are not allowed for this widget"
#
# Two phases (why deploying Firebase Functions alone does not fix “mobile not allowed” on Send OTP):
#   1. Client: Send OTP → MSG91 native SDK (`initializeWidget`, `sendOTP`) uses Widget ID + Auth Token below.
#      This step fails if Mobile Integration is off — Cloud Functions are never involved here.
#   2. Server: After OTP succeeds, `mintCustomToken` calls MSG91 verifyAccessToken using secret MSG91_AUTH_KEY.
#
# Checklist — MSG91 dashboard (you must do this in MSG91, not in code):
#   1. Open OTP / Login with OTP widget → enable **Mobile Integration** (React Native / mobile).
#   2. Optionally use a **separate** widget for Studio web (`studio/.../OTPLoginForm.tsx`) vs this app.
#   3. Copy that **mobile** widget’s Widget ID + Auth token into the variables below (or EAS env).
#   4. Rebuild / refresh bundle after changing widget vars:
#        npx expo start -c   # then reload the dev client
#        # If env still stale, rebuild native:
#        npx expo run:ios
#        npx expo run:android
#        # or EAS: eas build --profile development --platform ios|android
#
# Local dev: copy this file to `.env`, fill values, then `npx expo start -c` **and** rebuild native if you changed MSG91 vars.
# EAS: set the same keys for the build profile (plain or secret env) — see Expo “Environment variables”.
#
# If unset, the app uses fallbacks in `src/features/auth/studioAuth.ts` (those must also be a mobile-enabled widget).

EXPO_PUBLIC_MSG91_WIDGET_ID=
EXPO_PUBLIC_MSG91_TOKEN_AUTH=

# Dev-only (__DEV__): skip MSG91 for this exact E.164 number; verify with PIN via `mintDevTestToken`.
# Must match Firebase secrets DEV_LOGIN_PHONE + DEV_LOGIN_PIN (see `functions/src/devAuth.ts`).
# EXPO_PUBLIC_DEV_LOGIN_PHONE=+919999999999

# --- Firebase Cloud Functions (server-side MSG91) ---
# `mintCustomToken` calls MSG91 verifyAccessToken with the widget JWT from the app.
# Use the **Auth Key** MSG91 shows for “Server Side Integration” / verify widget token (dashboard dropdown).
# Never put this in EXPO_PUBLIC_* or commit it:
#   printf '%s' 'YOUR_MSG91_AUTH_KEY' | firebase functions:secrets:set MSG91_AUTH_KEY
# See `functions/src/auth.ts`.
